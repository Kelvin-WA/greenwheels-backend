# Copy this to .env and fill in your values
# DO NOT commit .env to Git — it contains secrets

# Your Google Sheets spreadsheet ID
# Found in the URL: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# Paste the full JSON content of your Google Service Account key file here (minified, on one line)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"..."}

# Port (Railway sets this automatically)
PORT=3000
